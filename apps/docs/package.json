{
  "name": "@roboport/docs",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vocs dev",
    "build": "vocs build",
    "preview": "vocs preview",
    "check": "bun run check:prettier && bun run check:eslint",
    "check:prettier": "prettier -c \"**/*.{json,js,ts,tsx}\" --ignore-path ../../.prettierignore",
    "check:eslint": "eslint \"**/*.{js,ts,tsx}\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-server-dom-webpack": "^19.2.0",
    "vite": "^8.0.0",
    "vocs": "^2.0.11",
    "waku": "1.0.0-beta.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.0"
  }
}
