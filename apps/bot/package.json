{
  "name": "@roboport/bot",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "start": "bun run src/index.ts",
    "dev": "bun --watch src/index.ts",
    "check": "bun run check:prettier && bun run check:eslint",
    "check:prettier": "prettier -c \"**/*.{json,js,ts}\"",
    "check:eslint": "eslint \"**/*.{js,ts}\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "roboport": "workspace:*",
    "hono": "^4.0.0"
  }
}
