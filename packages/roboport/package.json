{
  "name": "roboport",
  "version": "0.0.1",
  "author": {
    "name": "Timur Badretdinov",
    "url": "https://github.com/Destiner"
  },
  "license": "UNLICENSED",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./harness": "./src/harness/index.ts",
    "./mcp": "./src/mcp/index.ts",
    "./models": "./src/models/index.ts",
    "./skills": "./src/skills/index.ts",
    "./triggers": "./src/triggers/index.ts"
  },
  "scripts": {
    "check": "bun run check:prettier && bun run check:eslint",
    "check:prettier": "prettier -c \"**/*.{json,js,ts}\"",
    "check:eslint": "eslint \"**/*.{js,ts}\"",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "build": "rm -rf dist && bun run build:js && bun run build:types && bun run build:manifest",
    "build:js": "bun build ./src/index.ts ./src/harness/index.ts ./src/mcp/index.ts ./src/models/index.ts ./src/skills/index.ts ./src/triggers/index.ts --outdir ./dist --target bun --external zod --root ./src",
    "build:types": "tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json --resolve-full-paths",
    "build:manifest": "bun scripts/build-manifest.ts",
    "dist:pack": "bun run build && cd dist && bun pm pack --destination .."
  },
  "dependencies": {
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "tsc-alias": "^1.8.17"
  }
}
