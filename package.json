{
  "name": "drone-monorepo",
  "private": true,
  "type": "module",
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "check": "bun --filter '*' check",
    "check:prettier": "bun --filter '*' check:prettier",
    "check:eslint": "bun --filter '*' check:eslint",
    "typecheck": "bun --filter '*' typecheck",
    "docs": "bun --filter @drone/docs dev"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bun": "^1.3.10",
    "eslint": "^10.0.3",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import-x": "^4.16.1",
    "prettier": "^3.8.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.4"
  },
  "resolutions": {
    "@vitejs/plugin-rsc": "0.5.19"
  }
}
